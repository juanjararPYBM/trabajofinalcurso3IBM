    "# =============================================================================\n",
    "# SIMPLIFICACIÓN MODERADA - FIGURAS 2 Y 3 CONSOLIDADAS\n",
    "# Curso 3: Data Science Methodology - IBM Data Science Professional Certificate\n",
    "# =============================================================================\n",
    "\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "import os\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "# Configuración profesional\n",
    "plt.style.use('seaborn-v0_8-whitegrid')\n",
    "output_dir = './resultados_analisis'\n",
    "if not os.path.exists(output_dir):\n",
    "    os.makedirs(output_dir)\n",
    "\n",
    "# =============================================================================\n",
    "# VERIFICACIÓN Y CREACIÓN DE COLUMNAS DERIVADAS\n",
    "# =============================================================================\n",
    "\n",
    "def preparar_columnas(df):\n",
    "    \"\"\"Crea columnas derivadas si no existen\"\"\"\n",
    "    columnas_creadas = []\n",
    "    \n",
    "    if 'gender_label' not in df.columns:\n",
    "        df['gender_label'] = df['gender'].map({0: 'Mujeres', 1: 'Hombres'})\n",
    "        columnas_creadas.append('gender_label')\n",
    "    \n",
    "    if 'risk_label' not in df.columns:\n",
    "        df['risk_label'] = df['target'].map({0: 'Sin Riesgo', 1: 'Con Riesgo'})\n",
    "        columnas_creadas.append('risk_label')\n",
    "    \n",
    "    if 'age_group' not in df.columns:\n",
    "        df['age_group'] = pd.cut(df['age'], \n",
    "                                 bins=[19, 44, 54, 64, 80], \n",
    "                                 labels=['<45 años', '45-54 años', '55-64 años', '>65 años'])\n",
    "        columnas_creadas.append('age_group')\n",
    "    \n",
    "    # Diccionario de leyendas explícitas para todas las variables categóricas\n",
    "    df['chestpain_label'] = df['chestpain'].map({\n",
    "        0: 'Angina Típica', \n",
    "        1: 'Angina Atípica', \n",
    "        2: 'Dolor No Anginal', \n",
    "        3: 'Asintomático'\n",
    "    })\n",
    "    columnas_creadas.append('chestpain_label')\n",
    "    \n",
    "    df['slope_label'] = df['slope'].map({\n",
    "        1: 'Ascendente', \n",
    "        2: 'Plana', \n",
    "        3: 'Descendente'\n",
    "    })\n",
    "    columnas_creadas.append('slope_label')\n",
    "    \n",
    "    df['exang_label'] = df['exerciseangia'].map({\n",
    "        0: 'No', \n",
    "        1: 'Sí'\n",
    "    })\n",
    "    columnas_creadas.append('exang_label')\n",
    "    \n",
    "    if columnas_creadas:\n",
    "        print(f\"✅ Columnas creadas: {', '.join(columnas_creadas)}\")\n",
    "    \n",
    "    return df\n",
    "\n",
    "# Aplicar preparación\n",
    "df = preparar_columnas(df)\n",
    "\n",
    "print(f\"\\n📊 Dataset listo: {df.shape[0]} pacientes, {df.shape[1]} variables\")\n",
    "print(f\"📁 Directorio de salida: {output_dir}\")\n",
    "\n",
    "# =============================================================================\n",
    "# FIGURA 2: PERFIL SINTOMÁTICO Y PRESENTACIÓN CLÍNICA (3 subplots)\n",
    "# =============================================================================\n",
    "\n",
    "print(\"\\n\" + \"=\"*80)\n",
    "print(\"GENERANDO FIGURA 2: PERFIL SINTOMÁTICO Y PRESENTACIÓN CLÍNICA\")\n",
    "print(\"=\"*80)\n",
    "\n",
    "fig, axes = plt.subplots(1, 3, figsize=(20, 6))\n",
    "fig.suptitle('FIGURA 2: PERFIL SINTOMÁTICO Y PRESENTACIÓN CLÍNICA\\n'\n",
    "             'Análisis por Género y Estado de Riesgo Cardiovascular', \n",
    "             fontsize=16, fontweight='bold', y=1.02)\n",
    "\n",
    "# --- Subplot A: Tipo de Dolor Torácico (barras agrupadas) ---\n",
    "ax1 = axes[0]\n",
    "\n",
    "# Calcular porcentajes manualmente\n",
    "chestpain_summary = []\n",
    "for gender in [0, 1]:\n",
    "    for risk in [0, 1]:\n",
    "        subset = df[(df['gender'] == gender) & (df['target'] == risk)]\n",
    "        total = len(subset)\n",
    "        if total > 0:\n",
    "            for cp in [0, 1, 2, 3]:\n",
    "                count = (subset['chestpain'] == cp).sum()\n",
    "                chestpain_summary.append({\n",
    "                    'gender': 'Mujeres' if gender == 0 else 'Hombres',\n",
    "                    'risk': 'Sin Riesgo' if risk == 0 else 'Con Riesgo',\n",
    "                    'chestpain': ['Ang.Típ', 'Ang.Atíp', 'No Ang', 'Asint'][cp],\n",
    "                    'percentage': (count / total) * 100\n",
    "                })\n",
    "\n",
    "cp_df = pd.DataFrame(chestpain_summary)\n",
    "cp_pivot = cp_df.pivot_table(index=['gender', 'risk'], \n",
    "                              columns='chestpain', \n",
    "                              values='percentage').reset_index()\n",
    "\n",
    "# Crear barras agrupadas\n",
    "x = np.arange(4)\n",
    "width = 0.2\n",
    "colors = ['#3498db', '#e74c3c', '#2ecc71', '#f39c12']\n",
    "labels = ['Mujer Sin Riesgo', 'Mujer Con Riesgo', 'Hombre Sin Riesgo', 'Hombre Con Riesgo']\n",
    "\n",
    "for i, (idx, row) in enumerate(cp_pivot.iterrows()):\n",
    "    valores = [row['Ang.Típ'], row['Ang.Atíp'], row['No Ang'], row['Asint']]\n",
    "    ax1.bar(x + i*width, valores, width, label=labels[i], color=colors[i], alpha=0.85)\n",
    "\n",
    "ax1.set_ylabel('Porcentaje de Pacientes (%)', fontsize=11)\n",
    "ax1.set_xlabel('Tipo de Dolor Torácico', fontsize=11)\n",
    "ax1.set_title('A. Tipo de Dolor Torácico\\npor Género y Riesgo', \n",
    "              fontsize=11, fontweight='bold', pad=10)\n",
    "ax1.set_xticks(x + width * 1.5)\n",
    "ax1.set_xticklabels(['Angina\\nTípica', 'Angina\\nAtípica', 'Dolor No\\nAnginal', 'Asintomático'], \n",
    "                    fontsize=9)\n",
    "ax1.legend(loc='upper right', fontsize=8, title='Grupo de Pacientes')\n",
    "ax1.grid(axis='y', alpha=0.3)\n",
    "ax1.set_ylim(0, 80)\n",
    "\n",
    "# --- Subplot B: Angina Inducida por Ejercicio ---\n",
    "ax2 = axes[1]\n",
    "\n",
    "exang_summary = []\n",
    "for gender in [0, 1]:\n",
    "    for risk in [0, 1]:\n",
    "        subset = df[(df['gender'] == gender) & (df['target'] == risk)]\n",
    "        pct = subset['exerciseangia'].mean() * 100 if len(subset) > 0 else 0\n",
    "        exang_summary.append({\n",
    "            'gender': 'Mujeres' if gender == 0 else 'Hombres',\n",
    "            'risk': 'Sin Riesgo' if risk == 0 else 'Con Riesgo',\n",
    "            'percentage': pct\n",
    "        })\n",
    "\n",
    "exang_df = pd.DataFrame(exang_summary)\n",
    "exang_pivot = exang_df.pivot(index='gender', columns='risk', values='percentage')\n",
    "\n",
    "# Asegurar orden de columnas\n",
    "if 'Sin Riesgo' in exang_pivot.columns and 'Con Riesgo' in exang_pivot.columns:\n",
    "    exang_pivot = exang_pivot[['Sin Riesgo', 'Con Riesgo']]\n",
    "\n",
    "exang_pivot.plot(kind='bar', ax=ax2, color=['#3498db', '#e74c3c'], \n",
    "                 width=0.6, alpha=0.85)\n",
    "ax2.set_ylabel('Prevalencia (%)', fontsize=11)\n",
    "ax2.set_xlabel('Género', fontsize=11)\n",
    "ax2.set_title('B. Angina Inducida por Ejercicio\\n(% que desarrolla dolor con esfuerzo)', \n",
    "              fontsize=11, fontweight='bold', pad=10)\n",
    "ax2.set_xticklabels(['Mujeres', 'Hombres'], rotation=0, fontsize=10)\n",
    "ax2.legend(['Sin Riesgo Cardíaco', 'Con Riesgo Cardíaco'], \n",
    "           loc='upper left', fontsize=9, title='Estado Clínico')\n",
    "ax2.grid(axis='y', alpha=0.3)\n",
    "\n",
    "# Añadir valores sobre barras\n",
    "for container in ax2.containers:\n",
    "    ax2.bar_label(container, fmt='%.1f%%', fontsize=9, padding=3)\n",
    "\n",
    "# --- Subplot C: Heatmap de Presentación Clínica ---\n",
    "ax3 = axes[2]\n",
    "\n",
    "# Preparar datos para heatmap\n",
    "mujeres_riesgo = df[(df['gender'] == 0) & (df['target'] == 1)]\n",
    "hombres_riesgo = df[(df['gender'] == 1) & (df['target'] == 1)]\n",
    "\n",
    "heatmap_data = pd.DataFrame({\n",
    "    f'Mujeres con Riesgo\\n(n={len(mujeres_riesgo)})': [\n",
    "        (mujeres_riesgo['chestpain'] == 0).mean() * 100,\n",
    "        (mujeres_riesgo['chestpain'] == 1).mean() * 100,\n",
    "        (mujeres_riesgo['chestpain'] == 2).mean() * 100,\n",
    "        (mujeres_riesgo['chestpain'] == 3).mean() * 100,\n",
    "        mujeres_riesgo['exerciseangia'].mean() * 100\n",
    "    ],\n",
    "    f'Hombres con Riesgo\\n(n={len(hombres_riesgo)})': [\n",
    "        (hombres_riesgo['chestpain'] == 0).mean() * 100,\n",
    "        (hombres_riesgo['chestpain'] == 1).mean() * 100,\n",
    "        (hombres_riesgo['chestpain'] == 2).mean() * 100,\n",
    "        (hombres_riesgo['chestpain'] == 3).mean() * 100,\n",
    "        hombres_riesgo['exerciseangia'].mean() * 100\n",
    "    ]\n",
    "}, index=['Angina\\nTípica', 'Angina\\nAtípica', 'Dolor No\\nAnginal', \n",
    "          'Asintomático', 'Angina\\nInducida'])\n",
    "\n",
    "sns.heatmap(heatmap_data, annot=True, fmt='.1f', cmap='RdYlBu_r', ax=ax3,\n",
    "            cbar_kws={'label': 'Porcentaje (%)'}, vmin=0, vmax=100,\n",
    "            linewidths=0.5, linecolor='white')\n",
    "ax3.set_title('C. Perfil de Presentación Clínica\\nMujeres vs Hombres con Riesgo', \n",
    "              fontsize=11, fontweight='bold', pad=10)\n",
    "ax3.set_ylabel('Tipo de Presentación', fontsize=10)\n",
    "ax3.set_xlabel('Grupo de Pacientes', fontsize=10)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig(f'{output_dir}/figura2_perfil_sintomatico.png', dpi=300, bbox_inches='tight')\n",
    "plt.show()\n",
    "print(f\"✅ Figura 2 guardada: {output_dir}/figura2_perfil_sintomatico.png\")\n",
    "\n",
    "# =============================================================================\n",
    "# FIGURA 3: MARCADORES OBJETIVOS DE RIESGO (3 subplots)\n",
    "# =============================================================================\n",
    "\n",
    "print(\"\\n\" + \"=\"*80)\n",
    "print(\"GENERANDO FIGURA 3: MARCADORES OBJETIVOS DE RIESGO\")\n",
    "print(\"=\"*80)\n",
    "\n",
    "fig, axes = plt.subplots(1, 3, figsize=(20, 6))\n",
    "fig.suptitle('FIGURA 3: MARCADORES OBJETIVOS DE RIESGO CARDIOVASCULAR\\n'\n",
    "             'Variables Electrocardiográficas y Anatómicas', \n",
    "             fontsize=16, fontweight='bold', y=1.02)\n",
    "\n",
    "# REEMPLAZAR el Subplot A de la Figura 3 con este código:\n",
    "\n",
    "ax1 = axes[0]\n",
    "\n",
    "slope_summary = []\n",
    "for gender in [0, 1]:\n",
    "    for risk in [0, 1]:\n",
    "        subset = df[(df['gender'] == gender) & (df['target'] == risk)]\n",
    "        total = len(subset)\n",
    "        if total > 0:\n",
    "            for slope in [1, 2, 3]:\n",
    "                count = (subset['slope'] == slope).sum()\n",
    "                slope_summary.append({\n",
    "                    'gender': 'Mujeres' if gender == 0 else 'Hombres',\n",
    "                    'risk': 'Sin Riesgo' if risk == 0 else 'Con Riesgo',\n",
    "                    'slope': ['Ascendente', 'Plana', 'Descendente'][slope-1],\n",
    "                    'percentage': (count / total) * 100\n",
    "                })\n",
    "\n",
    "slope_df = pd.DataFrame(slope_summary)\n",
    "slope_pivot = slope_df.pivot_table(index=['gender', 'risk'], \n",
    "                                   columns='slope', \n",
    "                                   values='percentage').reset_index()\n",
    "\n",
    "x = np.arange(3)\n",
    "width = 0.2\n",
    "colors = ['#3498db', '#e74c3c', '#2ecc71', '#f39c12']\n",
    "labels = ['Mujer Sin Riesgo', 'Mujer Con Riesgo', 'Hombre Sin Riesgo', 'Hombre Con Riesgo']\n",
    "\n",
    "for i, (idx, row) in enumerate(slope_pivot.iterrows()):\n",
    "    valores = [row['Ascendente'], row['Plana'], row['Descendente']]\n",
    "    ax1.bar(x + i*width, valores, width, label=labels[i], color=colors[i], alpha=0.85)\n",
    "\n",
    "ax1.set_ylabel('Porcentaje de Pacientes (%)', fontsize=11)\n",
    "ax1.set_xlabel('Pendiente del Segmento ST', fontsize=11)\n",
    "ax1.set_title('A. Pendiente del Segmento ST\\n(Variable Maestra, r=0.80)', \n",
    "              fontsize=11, fontweight='bold', pad=10)\n",
    "ax1.set_xticks(x + width * 1.5)\n",
    "ax1.set_xticklabels(['Ascendente\\n(Normal)', 'Plana\\n(Sospechosa)', 'Descendente\\n(Isquemia)'], \n",
    "                    fontsize=9)\n",
    "\n",
    "# LEYENDA CORREGIDA - Fuera del área de trazado\n",
    "ax1.legend(loc='upper left', bbox_to_anchor=(1.02, 1), fontsize=8, \n",
    "           title='Grupo de Pacientes', frameon=True)\n",
    "\n",
    "ax1.grid(axis='y', alpha=0.3)\n",
    "ax1.set_ylim(0, 80)\n",
    "\n",
    "# Anotación de importancia - Reposicionada\n",
    "ax1.annotate('⚠️ Pendiente descendente = Alto riesgo', \n",
    "             xy=(2, 75), xytext=(2.5, 60),\n",
    "             fontsize=9, ha='left',\n",
    "             arrowprops=dict(arrowstyle='->', color='red', alpha=0.7),\n",
    "             bbox=dict(boxstyle='round,pad=0.3', facecolor='yellow', alpha=0.7))\n",
    "\n",
    "# --- Subplot B: Número de Vasos Coronarios Afectados ---\n",
    "ax2 = axes[1]\n",
    "\n",
    "vessels_summary = []\n",
    "for gender in [0, 1]:\n",
    "    for risk in [0, 1]:\n",
    "        subset = df[(df['gender'] == gender) & (df['target'] == risk)]\n",
    "        total = len(subset)\n",
    "        if total > 0:\n",
    "            for vessels in [0, 1, 2, 3]:\n",
    "                count = (subset['noofmajorvessels'] == vessels).sum()\n",
    "                vessels_summary.append({\n",
    "                    'gender': 'Mujeres' if gender == 0 else 'Hombres',\n",
    "                    'risk': 'Sin Riesgo' if risk == 0 else 'Con Riesgo',\n",
    "                    'vessels': f'{vessels} vasos',\n",
    "                    'percentage': (count / total) * 100\n",
    "                })\n",
    "\n",
    "vessels_df = pd.DataFrame(vessels_summary)\n",
    "vessels_pivot = vessels_df.pivot_table(index=['gender', 'risk'], \n",
    "                                       columns='vessels', \n",
    "                                       values='percentage').reset_index()\n",
    "\n",
    "x = np.arange(4)\n",
    "width = 0.2\n",
    "\n",
    "for i, (idx, row) in enumerate(vessels_pivot.iterrows()):\n",
    "    valores = [row['0 vasos'], row['1 vasos'], row['2 vasos'], row['3 vasos']]\n",
    "    ax2.bar(x + i*width, valores, width, label=labels[i], color=colors[i], alpha=0.85)\n",
    "\n",
    "ax2.set_ylabel('Porcentaje de Pacientes (%)', fontsize=11)\n",
    "ax2.set_xlabel('Número de Vasos Coronarios Afectados', fontsize=11)\n",
    "ax2.set_title('B. Carga de Enfermedad Coronaria\\n(Número de vasos principales afectados)', \n",
    "              fontsize=11, fontweight='bold', pad=10)\n",
    "ax2.set_xticks(x + width * 1.5)\n",
    "ax2.set_xticklabels(['0 vasos', '1 vaso', '2 vasos', '3 vasos'], fontsize=9)\n",
    "ax2.legend(loc='upper right', fontsize=8, title='Grupo')\n",
    "ax2.grid(axis='y', alpha=0.3)\n",
    "\n",
    "# --- Subplot C: Depresión del ST (oldpeak) - Boxplot comparativo ---\n",
    "ax3 = axes[2]\n",
    "\n",
    "# Preparar datos para boxplot\n",
    "boxplot_data = []\n",
    "for gender in [0, 1]:\n",
    "    for risk in [0, 1]:\n",
    "        subset = df[(df['gender'] == gender) & (df['target'] == risk)]\n",
    "        for value in subset['oldpeak']:\n",
    "            boxplot_data.append({\n",
    "                'gender': 'Mujeres' if gender == 0 else 'Hombres',\n",
    "                'risk': 'Sin Riesgo' if risk == 0 else 'Con Riesgo',\n",
    "                'oldpeak': value\n",
    "            })\n",
    "\n",
    "box_df = pd.DataFrame(boxplot_data)\n",
    "\n",
    "sns.boxplot(data=box_df, x='gender', y='oldpeak', hue='risk', ax=ax3, \n",
    "            palette=['#3498db', '#e74c3c'], width=0.6)\n",
    "ax3.set_ylabel('Depresión del Segmento ST (mm)', fontsize=11)\n",
    "ax3.set_xlabel('Género', fontsize=11)\n",
    "ax3.set_title('C. Depresión del ST (Oldpeak)\\n'\n",
    "              'Desnivel del ST en prueba de esfuerzo\\n'\n",
    "              'Valores >2 mm sugieren isquemia', \n",
    "              fontsize=11, fontweight='bold', pad=10)\n",
    "ax3.legend(['Sin Riesgo Cardíaco', 'Con Riesgo Cardíaco'], \n",
    "           loc='upper right', fontsize=9, title='Estado')\n",
    "ax3.grid(axis='y', alpha=0.3)\n",
    "\n",
    "# Añadir línea de referencia clínica\n",
    "ax3.axhline(y=2, color='red', linestyle='--', alpha=0.7, label='Umbral clínico (2 mm)')\n",
    "ax3.text(0.5, 2.2, 'Umbral clínico\\n(>2 mm = isquemia)', fontsize=8, color='red', ha='center')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig(f'{output_dir}/figura3_marcadores_riesgo.png', dpi=300, bbox_inches='tight')\n",
    "plt.show()\n",
    "print(f\"✅ Figura 3 guardada: {output_dir}/figura3_marcadores_riesgo.png\")\n",
    "\n",
    "# =============================================================================\n",
    "# RESUMEN EJECUTIVO DE HALLAZGOS\n",
    "# =============================================================================\n",
    "\n",
    "print(\"\\n\" + \"=\"*80)\n",
    "print(\"RESUMEN EJECUTIVO - HALLAZGOS CLAVE DE LAS FIGURAS 2 Y 3\")\n",
    "print(\"=\"*80)\n",
    "\n",
    "mujeres_riesgo = df[(df['gender'] == 0) & (df['target'] == 1)]\n",
    "hombres_riesgo = df[(df['gender'] == 1) & (df['target'] == 1)]\n",
    "\n",
    "# Estadísticas clave\n",
    "presentacion_atipica_mujeres = (mujeres_riesgo['chestpain'].isin([1, 2, 3])).mean() * 100\n",
    "presentacion_atipica_hombres = (hombres_riesgo['chestpain'].isin([1, 2, 3])).mean() * 100\n",
    "\n",
    "slope_descendente_mujeres = (mujeres_riesgo['slope'] == 3).mean() * 100\n",
    "slope_descendente_hombres = (hombres_riesgo['slope'] == 3).mean() * 100\n",
    "\n",
    "vasos_multiples_mujeres = (mujeres_riesgo['noofmajorvessels'] >= 2).mean() * 100\n",
    "vasos_multiples_hombres = (hombres_riesgo['noofmajorvessels'] >= 2).mean() * 100\n",
    "\n",
    "print(f\"\\n📊 FIGURA 2 - PERFIL SINTOMÁTICO:\")\n",
    "print(f\"   • Mujeres con riesgo: {presentacion_atipica_mujeres:.1f}% presentación ATÍPICA\")\n",
    "print(f\"   • Hombres con riesgo: {presentacion_atipica_hombres:.1f}% presentación ATÍPICA\")\n",
    "print(f\"   • Ratio: {presentacion_atipica_mujeres/presentacion_atipica_hombres:.1f}x más probabilidad en mujeres\")\n",
    "\n",
    "print(f\"\\n📊 FIGURA 3 - MARCADORES OBJETIVOS:\")\n",
    "print(f\"   • Pendiente ST descendente (isquemia):\")\n",
    "print(f\"     - Mujeres: {slope_descendente_mujeres:.1f}%\")\n",
    "print(f\"     - Hombres: {slope_descendente_hombres:.1f}%\")\n",
    "print(f\"   • Enfermedad multivaso (≥2 vasos):\")\n",
    "print(f\"     - Mujeres: {vasos_multiples_mujeres:.1f}%\")\n",
    "print(f\"     - Hombres: {vasos_multiples_hombres:.1f}%\")\n",
    "\n",
    "print(f\"\\n🔍 IMPLICACIÓN PARA EL SISTEMA DE ALERTA:\")\n",
    "print(f\"   Las mujeres requieren mayor énfasis en marcadores OBJETIVOS (ECG, slope)\")\n",
    "print(f\"   ya que sus síntomas subjetivos son menos fiables para diagnóstico.\")\n",
    "print(\"=\"*80)"
   ]
