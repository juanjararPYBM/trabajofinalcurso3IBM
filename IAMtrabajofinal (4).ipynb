    "\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "import os\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "# Install kagglehub if not already installed\n",
    "!pip install kagglehub\n",
    "\n",
    "# Download the dataset using kagglehub\n",
    "import kagglehub\n",
    "path = kagglehub.dataset_download(\"jocelyndumlao/cardiovascular-disease-dataset\")\n",
    "print(f\"Dataset downloaded to: {path}\")\n",
    "\n",
    "# Buscar el archivo CSV en el directorio descargado\n",
    "csv_path = None\n",
    "for root, dirs, files in os.walk(path):\n",
    "    for file in files:\n",
    "        if file.endswith('.csv'):\n",
    "            csv_path = os.path.join(root, file)\n",
    "            print(f\"Archivo encontrado: {file}\")\n",
    "            break\n",
    "    if csv_path:\n",
    "        break\n",
    "\n",
    "# Verificar si se encontró el archivo CSV\n",
    "if not csv_path:\n",
    "    raise FileNotFoundError(\"No se encontró ningún archivo CSV en el directorio descargado\")\n",
    "\n",
    "# Cargar el dataset\n",
    "df = pd.read_csv(csv_path)\n",
    "\n",
    "# Información básica\n",
    "print(\"=\" * 50)\n",
    "print(\"DIMENSIONES DEL DATASET\")\n",
    "print(\"=\" * 50)\n",
    "print(f\"Total de pacientes: {df.shape[0]}\")\n",
    "print(f\"Total de variables: {df.shape[1]}\")\n",
    "print(\"\\n\")\n",
    "\n",
    "print(\"=\" * 50)\n",
    "print(\"PRIMERAS 5 FILAS\")\n",
    "print(\"=\" * 50)\n",
    "print(df.head())\n",
    "print(\"\\n\")\n",
    "\n",
    "print(\"=\" * 50)\n",
    "print(\"INFORMACIÓN DE VARIABLES\")\n",
    "print(\"=\" * 50)\n",
    "print(df.info())\n",
    "print(\"\\n\")\n",
    "\n",
    "print(\"=\" * 50)\n",
    "print(\"ESTADÍSTICAS DESCRIPTIVAS\")\n",
    "print(\"=\" * 50)\n",
    "print(df.describe())\n"
   ]
