    "</tr>\n",
    "<tr style=\"background-color: #f9fbfd; border-bottom: 1px solid #eee;\">\n",
    "<td style=\"padding: 10px 15px; font-weight: bold; color: #2980b9;\">chestpain</td>\n",
    "<td style=\"padding: 10px 15px;\">Tipo de dolor de pecho</td>\n",
    "<td style=\"padding: 10px 15px;\"><span style=\"background: #e8f8f5; padding: 2px 6px; border-radius: 4px; color: #16a085;\">Categórica</span></td>\n",
    "<td style=\"padding: 10px 15px; font-size: 0.85em;\">0:angina típica, 1:atípica, 2:no anginal, 3:asintomático</td>\n",
    "</tr>\n",
    "<tr style=\"border-bottom: 1px solid #eee;\">\n",
