    "<td style=\"padding: 10px 15px;\">0=No, 1=Sí</td>\n",
    "</tr>\n",
    "<tr style=\"background-color: #f9fbfd; border-bottom: 1px solid #eee;\">\n",
    "<td style=\"padding: 10px 15px; font-weight: bold; color: #2980b9;\">restingrelectro</td>\n",
    "<td style=\"padding: 10px 15px;\">Resultado ECG en reposo</td>\n",
