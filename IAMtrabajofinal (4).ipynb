    "<td style=\"padding: 10px 15px;\">71-202 lpm</td>\n",
    "</tr>\n",
    "<tr style=\"background-color: #f9fbfd; border-bottom: 1px solid #eee;\">\n",
    "<td style=\"padding: 10px 15px; font-weight: bold; color: #2980b9;\">exerciseangia</td>\n",
    "<td style=\"padding: 10px 15px;\">Angina inducida por ejercicio</td>\n",
    "<td style=\"padding: 10px 15px;\"><span style=\"background: #fdf2e9; padding: 2px 6px; border-radius: 4px; color: #d35400;\">Binaria</span></td>\n",
    "<td style=\"padding: 10px 15px;\">0=No, 1=Sí</td>\n",
    "</tr>\n",
    "<tr style=\"border-bottom: 1px solid #eee;\">\n",
