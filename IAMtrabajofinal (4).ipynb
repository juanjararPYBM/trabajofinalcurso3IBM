    "            chestpain_data.append({\n",
    "                'gender': 'Mujeres' if gender == 0 else 'Hombres',\n",
    "                'risk': 'Sin Riesgo' if risk == 0 else 'Con Riesgo',\n",
    "                'chestpain_type': ['Ang.Típ', 'Ang.Atíp', 'No Ang', 'Asint'][cp_type],\n",
    "                'percentage': pct\n",
