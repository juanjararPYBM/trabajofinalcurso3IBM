    "</tr>\n",
    "<tr style=\"background-color: #f9fbfd; border-bottom: 1px solid #eee;\">\n",
    "<td style=\"padding: 10px 15px; font-weight: bold; color: #2980b9;\">serumcholestrol</td>\n",
    "<td style=\"padding: 10px 15px;\">Colesterol en sangre</td>\n",
    "<td style=\"padding: 10px 15px;\"><span style=\"background: #f4f6f7; padding: 2px 6px; border-radius: 4px;\">Numérica</span></td>\n",
    "<td style=\"padding: 10px 15px;\">0-602 mg/dl</td>\n",
    "</tr>\n",
    "<tr style=\"border-bottom: 1px solid #eee;\">\n",
    "<td style=\"padding: 10px 15px; font-weight: bold; color: #2980b9;\">fastingbloodsugar</td>\n",
