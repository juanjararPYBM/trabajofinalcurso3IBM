    "# =============================================================================\n",
    "# FIGURA 2: PERFIL SINTOMÁTICO Y PRESENTACIÓN CLÍNICA (CONSOLIDADA)\n",
    "# CORREGIDO - Verificación de columnas incluida\n",
    "# =============================================================================\n",
    "\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "import os\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "# Verificar y crear columnas derivadas si no existen\n",
    "if 'gender_label' not in df.columns:\n",
    "    df['gender_label'] = df['gender'].map({0: 'Mujeres', 1: 'Hombres'})\n",
    "    print(\"✅ Columna 'gender_label' creada\")\n",
    "\n",
    "if 'risk_label' not in df.columns:\n",
    "    df['risk_label'] = df['target'].map({0: 'Sin Riesgo Cardíaco', 1: 'Con Riesgo Cardíaco'})\n",
    "    print(\"✅ Columna 'risk_label' creada\")\n",
    "\n",
    "if 'age_group' not in df.columns:\n",
    "    df['age_group'] = pd.cut(df['age'], \n",
    "                             bins=[19, 44, 54, 64, 80], \n",
    "                             labels=['<45 años', '45-54 años', '55-64 años', '>65 años'])\n",
    "    print(\"✅ Columna 'age_group' creada\")\n",
    "\n",
    "# Crear directorio de salida\n",
    "output_dir = './resultados_analisis'\n",
    "if not os.path.exists(output_dir):\n",
    "    os.makedirs(output_dir)\n",
    "\n",
    "fig, axes = plt.subplots(1, 3, figsize=(18, 6))\n",
    "fig.suptitle('FIGURA 2: PERFIL SINTOMÁTICO Y PRESENTACIÓN CLÍNICA\\n'\n",
    "             'Comparativa por Género y Estado de Riesgo Cardiovascular', \n",
    "             fontsize=14, fontweight='bold', y=1.02)\n",
    "\n",
    "# =============================================================================\n",
    "# Subplot A: Tipo de Dolor Torácico (gráfico de barras agrupado)\n",
    "# =============================================================================\n",
    "ax1 = axes[0]\n",
    "\n",
    "# Preparar datos para visualización clara\n",
    "chestpain_data = []\n",
    "for gender in [0, 1]:\n",
    "    for risk in [0, 1]:\n",
    "        subset = df[(df['gender'] == gender) & (df['target'] == risk)]\n",
    "        for cp_type in [0, 1, 2, 3]:\n",
    "            count = (subset['chestpain'] == cp_type).sum()\n",
