    "# ====================== RECARGA TOTAL + EDA (Data Understanding) ======================\n",
    "# importamos y descargamos de nuevo para evitar tracebacks por variables no reconocidas\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "import os\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "print(\"🔄 Iniciando recarga completa del dataset...\\n\")\n",
    "\n",
    "# 1. Descargar dataset (solo la primera vez o si no existe)\n",
    "try:\n",
    "    import kagglehub\n",
    "    path = kagglehub.dataset_download(\"jocelyndumlao/cardiovascular-disease-dataset\")\n",
    "    print(f\"✅ Dataset descargado en: {path}\")\n",
    "except:\n",
    "    !pip install kagglehub\n",
    "    import kagglehub\n",
    "    path = kagglehub.dataset_download(\"jocelyndumlao/cardiovascular-disease-dataset\")\n",
    "    print(f\"✅ Dataset descargado en: {path}\")\n",
    "\n",
    "# 2. Buscar y cargar el CSV\n",
    "csv_path = None\n",
    "for root, dirs, files in os.walk(path):\n",
    "    for file in files:\n",
    "        if file.endswith('.csv'):\n",
    "            csv_path = os.path.join(root, file)\n",
    "            print(f\"✅ Archivo encontrado: {file}\")\n",
    "            break\n",
    "    if csv_path:\n",
    "        break\n",
    "\n",
    "if not csv_path:\n",
    "    raise FileNotFoundError(\"No se encontró el CSV\")\n",
    "\n",
    "df = pd.read_csv(csv_path)\n",
    "print(f\"✅ Dataset cargado correctamente: {df.shape[0]} pacientes, {df.shape[1]} columnas\\n\")\n",
    "\n",
    "\n",
    "\n",
    "# ====================== EDA - ANÁLISIS EXPLORATORIO ======================\n",
    "print(\"=\"*70)\n",
    "print(\"DISTRIBUCIÓN DEL TARGET (riesgo cardíaco)\")\n",
    "print(\"=\"*70)\n",
    "print(df['target'].value_counts(normalize=True).round(4))\n",
    "print(f\"→ {df['target'].value_counts()[1]} pacientes CON riesgo (58%)\")\n",
    "print(f\"→ {df['target'].value_counts()[0]} pacientes SIN riesgo (42%)\")\n",
    "\n",
    "sns.set_style(\"whitegrid\")\n",
    "\n",
    "# Gráfico 1: Distribución target\n",
    "plt.figure(figsize=(6,4))\n",
    "sns.countplot(x='target', data=df, palette='viridis')\n",
    "plt.title('Distribución de pacientes con y sin riesgo de evento isquémico', fontsize=14)\n",
    "plt.xlabel('Target (0 = Bajo riesgo, 1 = Alto riesgo)')\n",
    "plt.ylabel('Cantidad de pacientes')\n",
    "plt.show()\n",
    "\n",
    "# Gráfico 2: Edad vs Riesgo\n",
    "plt.figure(figsize=(10,5))\n",
    "sns.histplot(data=df, x='age', hue='target', kde=True, bins=20, palette='viridis')\n",
    "plt.title('Distribución de Edad según Riesgo Cardíaco')\n",
    "plt.xlabel('Edad (años)')\n",
    "plt.axvline(x=45, color='red', linestyle='--', alpha=0.7)\n",
    "plt.text(45, 42, 'Pico prematuro\\n(≈45 años)', color='red', ha='center', fontweight='bold')\n",
    "plt.show()\n",
    "\n",
    "# Gráfico 3: Matriz de correlación\n",
    "numeric_cols = ['age', 'restingBP', 'serumcholestrol', 'maxheartrate', 'oldpeak','noofmajorvessels', 'chestpain', 'slope', 'target']\n",
    "corr = df[numeric_cols].corr()\n",
    "plt.figure(figsize=(10,8))\n",
    "sns.heatmap(corr, annot=True, cmap='coolwarm', center=0, fmt='.2f')\n",
    "plt.title('Matriz de Correlación (variables numéricas)')\n",
    "plt.show()\n",
    "\n",
    "# ====================== ANÁLISIS PRECISO DE CORRELACIONES ======================\n",
    "print(\"=\"*80)\n",
    "print(\"CORRELACIONES EXACTAS CON EL TARGET (ordenadas de mayor a menor)\")\n",
    "print(\"=\"*80)\n",
    "\n",
    "# Solo variables numéricas + target\n",
    "corr_with_target = df.corr(numeric_only=True)['target'].sort_values(ascending=False)\n",
    "\n",
    "print(corr_with_target.round(4))\n",
    "\n",
    "# Para ver la matriz completa (opcional, pero útil para comparar)\n",
    "print(\"\\nMatriz completa (solo las más relevantes):\")\n",
    "print(df[['slope', 'chestpain', 'noofmajorvessels', 'oldpeak', 'restingBP', 'target']].corr().round(4))\n",
    "\n",
    "# Gráfico 4: Boxplots outliers\n",
    "plt.figure(figsize=(12,5))\n",
    "df[['restingBP', 'serumcholestrol', 'maxheartrate', 'oldpeak']].boxplot()\n",
    "plt.title('Detección de Outliers en variables clave')\n",
    "plt.ylabel('Valor')\n",
    "plt.xticks(rotation=45)\n",
    "plt.show()\n",
    "\n",
    "# ====================== VISUALIZACIÓN FINAL - VARIABLES CATEGÓRICAS (TODO EN ESPAÑOL) ======================\n",
    "import seaborn as sns\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "print(\"=\"*90)\n",
    "print(\"ANÁLISIS DETALLADO DE VARIABLES CATEGÓRICAS\")\n",
    "print(\"=\"*90)\n",
    "\n",
    "# Variables a graficar\n",
    "categorical_vars = ['gender', 'chestpain', 'fastingbloodsugar', \n",
    "                    'restingrelectro', 'exerciseangia', 'slope', \n",
    "                    'noofmajorvessels']\n",
    "\n",
    "# Etiquetas completas y descriptivas en español para títulos y ejes\n",
    "titulos_es = {\n",
    "    'gender': 'Género',\n",
    "    'chestpain': 'Tipo de Dolor de Pecho',\n",
    "    'fastingbloodsugar': 'Azúcar en Ayunas',\n",
    "    'restingrelectro': 'Resultado de ECG en Reposo',\n",
    "    'exerciseangia': 'Angina Inducida por Ejercicio',\n",
    "    'slope': 'Pendiente del Segmento ST',\n",
    "    'noofmajorvessels': 'Número de Vasos Coronarios Afectados'\n",
    "}\n",
    "\n",
    "# Etiquetas del eje X (más claras y descriptivas)\n",
    "x_labels_es = {\n",
    "    'gender': ['Mujer', 'Hombre'],\n",
    "    'chestpain': ['Angina Típica', 'Angina Atípica', 'Dolor No Anginal', 'Asintomático'],\n",
    "    'fastingbloodsugar': ['≤ 120 mg/dl', '> 120 mg/dl'],\n",
    "    'restingrelectro': ['Normal', 'Anormalidad ST-T', 'Hipertrofia Ventricular Izquierda'],\n",
    "    'exerciseangia': ['No', 'Sí'],\n",
    "    'slope': ['Ascendente', 'Plana', 'Descendente'],\n",
    "    'noofmajorvessels': ['0 vasos', '1 vaso', '2 vasos', '3 vasos']\n",
    "}\n",
    "\n",
    "# Crear figura con 2 gráficas por fila (muy limpio)\n",
    "fig, axes = plt.subplots(4, 2, figsize=(18, 20))\n",
    "axes = axes.flatten()\n",
    "\n",
    "for i, var in enumerate(categorical_vars):\n",
    "    ax = axes[i]\n",
    "    \n",
    "    sns.countplot(x=var, hue='target', data=df, palette='viridis', ax=ax)\n",
    "    \n",
    "    # Título completamente en español\n",
    "    ax.set_title(f'Distribución de {titulos_es[var]} según Riesgo Cardíaco', \n",
    "                 fontsize=14, pad=15)\n",
    "    \n",
    "    # Etiquetas del eje X claras y descriptivas\n",
    "    ax.set_xticks(range(len(x_labels_es[var])))\n",
    "    ax.set_xticklabels(x_labels_es[var], rotation=15, ha='right', fontsize=11)\n",
    "    \n",
    "    ax.set_xlabel('')\n",
    "    ax.set_ylabel('Cantidad de Pacientes', fontsize=12)\n",
    "    \n",
    "    # Leyenda clara\n",
    "    ax.legend(title='Riesgo Cardíaco', \n",
    "              labels=['Sin Riesgo', 'Con Riesgo'], \n",
    "              fontsize=11, title_fontsize=12, loc='upper right')\n",
    "\n",
    "# Ocultar subplot vacío\n",
    "axes[-1].set_visible(False)\n",
    "\n",
    "plt.suptitle('Análisis de Variables Categóricas y su Relación con el Riesgo de Evento Isquémico', \n",
    "             fontsize=18, fontweight='bold', y=0.98)\n",
    "plt.tight_layout(rect=[0, 0, 1, 0.96])\n",
    "plt.show()\n",
    "\n"
   ]
