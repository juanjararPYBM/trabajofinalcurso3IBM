    "<div style=\"font-family: 'Segoe UI', sans-serif; margin-top: 25px;\">\n",
    "<h3 style=\"color: #2e6171; border-left: 5px solid #2e6171; padding-left: 10px; margin-bottom: 15px;\">Diccionario de Datos: Significado Clínico</h3>\n",
